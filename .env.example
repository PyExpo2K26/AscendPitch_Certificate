# Flask Configuration
FLASK_SECRET_KEY=replace-with-strong-secret

# GitHub Configuration
# Get your personal access token from: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
# Token format should be: ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub repository in the format: organization-name/repository-name
# Example: "AscendPitch/event-certificates"
GITHUB_REPO=your-username/your-repo

# Branch to upload certificates to (default: main)
GITHUB_BRANCH=main

# Folder within the repository to upload certificates to (optional, can be empty for root)
# Example: "generated-certificates" will upload to /generated-certificates/ folder in repo
GITHUB_CERT_FOLDER=generated-certificates

# Email Configuration
# The app always sends from: pyexpo@kgkite.ac.in

# Generate app password from: https://myaccount.google.com/apppasswords
# This is NOT your regular Gmail password
MAIL_PASSWORD=your-app-password

# Optional legacy alias used by email_sender.py
GMAIL_APP_PASSWORD=your-app-password

# Optional storage path for generated files.
# On Render, this can point to your mounted disk, for example: /var/data/ascendpitch
APP_STORAGE_DIR=/var/data/ascendpitch
